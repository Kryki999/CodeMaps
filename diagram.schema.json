{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://codemaps.local/diagram.schema.json",
  "title": "CodeMaps Diagram",
  "description": "Schema for CodeMaps architecture diagrams edited by Cursor agents (v1.1 — C4 nesting)",
  "type": "object",
  "required": ["version", "metadata", "viewport", "nodes", "edges"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "string", "enum": ["1.0", "1.1"] },
    "metadata": {
      "type": "object",
      "required": ["name", "createdAt", "updatedAt"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "viewport": {
      "type": "object",
      "required": ["x", "y", "zoom"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "zoom": { "type": "number", "minimum": 0.1, "maximum": 4 }
      }
    },
    "viewportsByParent": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["x", "y", "zoom"],
        "properties": {
          "x": { "type": "number" },
          "y": { "type": "number" },
          "zoom": { "type": "number", "minimum": 0.1, "maximum": 4 }
        }
      }
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/definitions/node" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/definitions/edge" }
    }
  },
  "definitions": {
    "node": {
      "type": "object",
      "required": ["id", "type", "label"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "description": "Unique kebab-case identifier"
        },
        "type": {
          "type": "string",
          "enum": ["service", "database", "component", "queue", "cache", "external", "group"]
        },
        "label": { "type": "string", "minLength": 1 },
        "parentId": {
          "type": ["string", "null"],
          "description": "Parent node id for C4 nesting; null/omitted = root level"
        },
        "position": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "data": {
          "type": "object",
          "properties": {
            "tech": { "type": "array", "items": { "type": "string" } },
            "purpose": {
              "type": "string",
              "description": "Plain-language role: what this is for, what it does (non-technical)"
            },
            "rationale": {
              "type": "string",
              "description": "Why this approach: product intent, UX/psychology, business, trade-offs, rejected alternatives — living memory for humans and agents"
            },
            "description": {
              "type": "string",
              "description": "Technical notes for developers and agents"
            },
            "status": {
              "type": "string",
              "enum": ["planned", "existing", "deprecated"],
              "description": "Lifecycle status"
            },
            "health": {
              "type": "string",
              "enum": ["stable", "warning", "critical"],
              "description": "Runtime / audit health"
            },
            "codeRef": { "type": ["string", "null"], "description": "Path to source file in repo" },
            "exports": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Important functions / exported types"
            },
            "deps": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Key libraries / dependencies"
            },
            "depthHint": {
              "type": "integer",
              "enum": [1, 2, 3],
              "description": "Optional C4 depth hint for agents"
            }
          }
        }
      }
    },
    "edge": {
      "type": "object",
      "required": ["id", "source", "target"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "source": { "type": "string" },
        "target": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["http", "websocket", "event", "dependency", "data-flow"]
        },
        "label": { "type": "string" },
        "animated": { "type": "boolean" },
        "dashed": { "type": "boolean" },
        "sourceHandle": { "type": "string" },
        "targetHandle": { "type": "string" }
      }
    }
  }
}
